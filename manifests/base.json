{
  "manifest_version": 3,
  "name": "Dollar Commander",
  "version": "0.1.0",
  "author": "Nate Finch",
  "homepage_url": "https://github.com/natefinch/dollar-commander",
  "description": "Dollar Commander overlays historical USD 1.00 price-legality information on Magic: The Gathering deck and search sites.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://moxfield.com/*",
    "https://archidekt.com/*",
    "https://scryfall.com/*"
  ],
  "icons": {
    "16": "icons/dollar-commander-16.png",
    "32": "icons/dollar-commander-32.png",
    "48": "icons/dollar-commander-48.png",
    "64": "icons/dollar-commander-64.png",
    "128": "icons/dollar-commander-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://moxfield.com/*",
        "https://archidekt.com/*",
        "https://scryfall.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://moxfield.com/*",
        "https://archidekt.com/*",
        "https://scryfall.com/*"
      ],
      "js": [
        "content-main.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/dollar-commander-16.png",
      "32": "icons/dollar-commander-32.png",
      "48": "icons/dollar-commander-48.png",
      "64": "icons/dollar-commander-64.png",
      "128": "icons/dollar-commander-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Dollar Commander"
  }
}
